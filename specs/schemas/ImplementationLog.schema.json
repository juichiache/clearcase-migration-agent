{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/juichiache/clearcase-migration-agent/specs/schemas/ImplementationLog.schema.json",
  "title": "ImplementationLog",
  "description": "Records all files generated by the Implementation Agent, linked to package names and planning run tasks. Tracks CI status per package.",
  "type": "object",
  "required": ["runId", "planRunId", "timestamp", "packages"],
  "additionalProperties": false,
  "properties": {
    "runId": {
      "type": "string",
      "description": "This implementation run's ID"
    },
    "planRunId": {
      "type": "string",
      "description": "The planning run ID whose artifacts this implementation run is based on"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Last updated timestamp"
    },
    "packages": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/PackageImplementation"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "totalPackages": { "type": "integer", "minimum": 0 },
        "ciPassing": { "type": "integer", "minimum": 0 },
        "ciFailing": { "type": "integer", "minimum": 0 },
        "ciPending": { "type": "integer", "minimum": 0 },
        "merged": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "definitions": {
    "PackageImplementation": {
      "type": "object",
      "required": ["packageName", "planTaskRef", "generatedFiles", "ciStatus"],
      "additionalProperties": false,
      "properties": {
        "packageName": { "type": "string" },
        "planTaskRef": {
          "type": "string",
          "description": "Reference to the PackageAssignment entry (e.g., 'assignment-libcore-20241215')"
        },
        "generatedFiles": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GeneratedFile"
          }
        },
        "prUrl": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL of the GitHub PR opened for this package"
        },
        "prNumber": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "ciStatus": {
          "type": "string",
          "enum": ["pending", "passing", "failing", "merged", "blocked"],
          "description": "Current CI status for this package's PR"
        },
        "ciRunUrl": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "implementedAt": {
          "type": "string",
          "format": "date-time"
        },
        "buildErrorReportRef": {
          "type": ["string", "null"],
          "description": "Path to BuildErrorReport.json if CI failed"
        }
      }
    },
    "GeneratedFile": {
      "type": "object",
      "required": ["type", "path"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cmake", "conan", "copymap", "patch", "other"]
        },
        "path": {
          "type": "string",
          "description": "Relative path to the generated file"
        },
        "lineCount": {
          "type": "integer",
          "minimum": 0
        },
        "sha": {
          "type": "string",
          "description": "SHA-256 hash of file contents for reproducibility verification"
        }
      }
    }
  }
}
